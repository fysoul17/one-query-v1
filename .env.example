# Required (or other backend key)
ANTHROPIC_API_KEY=

# Data volume path
DATA_DIR=/data

# Runtime server port
PORT=3001

# Dashboard → Runtime URL
RUNTIME_URL=http://runtime:3001

# CLI backend: claude | codex | gemini
AI_BACKEND=claude

# Agent idle timeout (ms)
IDLE_TIMEOUT_MS=300000

# Max concurrent agents
MAX_AGENTS=10

# Vector DB: lancedb | qdrant
VECTOR_PROVIDER=lancedb

# Qdrant URL (if using Qdrant)
# QDRANT_URL=http://qdrant:6333

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Deployment mode: standalone | managed
MODE=standalone
