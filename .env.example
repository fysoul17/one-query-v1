# Data volume path (use ./data for local dev, /data for Docker)
DATA_DIR=./data

# Runtime server port (default: 7820)
PORT=7820

# Memory server port (default: 7822)
MEMORY_SERVER_PORT=7822

# Dashboard → Runtime URL (use http://localhost:7820 for local dev, http://runtime:7820 for Docker)
RUNTIME_URL=http://localhost:7820

# CLI backend: claude | codex | gemini
AI_BACKEND=claude

# Agent idle timeout (ms)
IDLE_TIMEOUT_MS=300000

# Max concurrent agents
MAX_AGENTS=10

# Vector DB: lancedb | qdrant
VECTOR_PROVIDER=lancedb

# Qdrant URL (if using Qdrant)
# QDRANT_URL=http://qdrant:6333

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Deployment mode: standalone | managed
MODE=standalone
