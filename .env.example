# Data volume path (use ./data for local dev, /data for Docker)
DATA_DIR=./data

# Runtime server port (default: 7820)
PORT=7820

# Memory server port (default: 7822)
MEMORY_SERVER_PORT=7822

# Dashboard → Runtime URL (use http://localhost:7820 for local dev, http://runtime:7820 for Docker)
RUNTIME_URL=http://localhost:7820

# CLI backend: claude | codex | gemini | pi | ollama
AI_BACKEND=claude

# Codex CLI API key (OpenAI)
# CODEX_API_KEY=sk-...

# Gemini CLI API key (Google)
# GEMINI_API_KEY=AIzaSy...

# Pi CLI API key (multi-provider gateway)
# PI_API_KEY=pi-...
# PI_MODEL=openai/gpt-4.1

# Ollama (local LLM — no API key needed, just run `ollama serve`)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# Agent idle timeout (ms)
IDLE_TIMEOUT_MS=300000

# Max concurrent agents
MAX_AGENTS=10

# Vector DB: lancedb | qdrant
VECTOR_PROVIDER=lancedb

# Embedding provider (used by pyx-memory sidecar in Docker full profile): local | anthropic | openai | stub
# EMBEDDING_PROVIDER=stub

# Qdrant URL (if using Qdrant)
# QDRANT_URL=http://qdrant:6333

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Deployment mode: standalone | managed
MODE=standalone

# Rate limiting (requests per window per IP)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
TRUST_PROXY=false

# Stream timeout (ms) for AI backend responses
STREAM_TIMEOUT_MS=300000

# Dashboard authentication (disabled by default)
# Set both DASHBOARD_USER and DASHBOARD_PASSWORD to enable login
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=changeme
# DASHBOARD_SECRET=optional-separate-signing-key
# DASHBOARD_SESSION_TTL=86400
