## ── Required ──────────────────────────────────────────────────
DATA_DIR=./data
PORT=7820
AI_BACKEND=claude

## ── Optional ─────────────────────────────────────────────────
# FALLBACK_BACKEND=ollama
IDLE_TIMEOUT_MS=300000
MAX_AGENTS=10
LOG_LEVEL=info
# CORS_ORIGIN=https://yourdomain.com

## ── AI Backend Keys (set the one matching AI_BACKEND) ────────
# ANTHROPIC_API_KEY=sk-ant-...
# CODEX_API_KEY=sk-...
# GEMINI_API_KEY=AIzaSy...
# PI_API_KEY=pi-...
# PI_MODEL=openai/gpt-4.1
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

## ── Memory ───────────────────────────────────────────────────
VECTOR_PROVIDER=lancedb
# QDRANT_URL=http://qdrant:6333
# EMBEDDING_PROVIDER=stub
MEMORY_SERVER_PORT=7822
# MEMORY_URL auto-derives from MEMORY_SERVER_PORT when not set.
# Set explicitly to override (e.g., for Docker: http://memory:7822)
# MEMORY_URL=http://localhost:7822

## ── Production ───────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
TRUST_PROXY=false
STREAM_TIMEOUT_MS=300000
MODE=standalone
RUNTIME_URL=http://localhost:7820

## ── Feature Flags ────────────────────────────────────────────
# ENABLE_TERMINAL_WS=false
# ENABLE_ADVANCED_MEMORY=false
# ENABLE_DEBUG_WS=true
# DEBUG_WS_TOKEN=
