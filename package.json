{
  "name": "agent-runtime",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "dashboard"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "biome check packages/ dashboard/",
    "lint:fix": "biome check --write packages/ dashboard/",
    "format": "biome format --write packages/ dashboard/",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "dev:runtime": "turbo run dev --filter=@autonomy/server",
    "dev:dashboard": "turbo run dev --filter=@autonomy/dashboard",
    "docker:up": "docker compose -f docker/docker-compose.yaml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yaml down",
    "docker:build": "docker compose -f docker/docker-compose.yaml build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/bun": "^1.2.4",
    "turbo": "^2.4",
    "typescript": "^5.7"
  },
  "packageManager": "bun@1.3.10"
}
