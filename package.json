{
  "name": "agent-runtime",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "dashboard",
    "vendor/pyx-memory/packages/shared",
    "vendor/pyx-memory/packages/client",
    "vendor/pyx-memory/packages/core",
    "vendor/pyx-memory/packages/dashboard"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "dev:runtime": "turbo run dev --filter=@autonomy/server",
    "dev:dashboard": "turbo run dev --filter=@autonomy/dashboard",
    "docker:up": "docker compose -f docker/docker-compose.yaml up --build",
    "docker:down": "docker compose -f docker/docker-compose.yaml down",
    "docker:build": "docker compose -f docker/docker-compose.yaml build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/bun": "latest",
    "turbo": "^2.4",
    "typescript": "^5.7"
  },
  "packageManager": "bun@1.2.4"
}
