# Dockerfile.runtime — Bun-based runtime server
# Runs the agent runtime (HTTP API + WebSocket + Conductor + Memory + CronManager)

FROM oven/bun:1.2.16

WORKDIR /app

# Install dependencies
# All workspace package.json files must be present for bun to resolve the lockfile.
# When adding a new workspace, update all 3 Dockerfiles (runtime, dashboard, memory).
COPY package.json bun.lock* ./
COPY packages/shared/package.json ./packages/shared/
COPY packages/agent-manager/package.json ./packages/agent-manager/
COPY packages/memory/package.json ./packages/memory/
COPY packages/conductor/package.json ./packages/conductor/
COPY packages/cron-manager/package.json ./packages/cron-manager/
COPY packages/server/package.json ./packages/server/
COPY packages/control-plane/package.json ./packages/control-plane/
COPY packages/memory-server/package.json ./packages/memory-server/
COPY packages/plugin-system/package.json ./packages/plugin-system/
COPY dashboard/package.json ./dashboard/

RUN bun install --frozen-lockfile || bun install

# Install Node.js 22 (required for npm-based CLI tools)
RUN apt-get update && \
    apt-get install -y --no-install-recommends curl ca-certificates && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Install AI CLI backends
RUN npm install -g @anthropic-ai/claude-code @openai/codex @google/gemini-cli

# Copy source (Bun runs TS directly — no build step)
COPY tsconfig.base.json ./
COPY packages/ ./packages/

# Create data directory with seed files
RUN mkdir -p /data/agents /data/memory /data/vectors /data/workspaces \
             /data/cli-config/claude /data/cli-config/codex /data/cli-config/gemini /data/cli-config/pi && \
    chmod 700 /data/cli-config/claude /data/cli-config/codex /data/cli-config/gemini /data/cli-config/pi && \
    chown -R bun:bun /data

COPY --chown=bun:bun data/config.json /data/config.json
COPY --chown=bun:bun data/crons.json /data/crons.json
COPY --chown=bun:bun data/agents/registry.json /data/agents/registry.json

# Runtime config
ENV DATA_DIR=/data
ENV PORT=7820
ENV AI_BACKEND=claude
ENV IDLE_TIMEOUT_MS=300000
ENV MAX_AGENTS=10
ENV VECTOR_PROVIDER=lancedb
ENV LOG_LEVEL=info
ENV MODE=standalone
ENV XDG_CONFIG_HOME=/data/cli-config
ENV CLAUDE_CONFIG_DIR=/data/cli-config/claude
ENV CODEX_HOME=/data/cli-config/codex
ENV GEMINI_CLI_HOME=/data/cli-config/gemini

USER bun

EXPOSE 7820

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD bun -e "fetch('http://localhost:7820/health').then(r => r.ok ? process.exit(0) : process.exit(1)).catch(() => process.exit(1))"

CMD ["bun", "packages/server/src/index.ts"]
