{
  "name": "@autonomy/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:e2e": "bun test __tests__/e2e/ --timeout 30000",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "clean": "rm -rf node_modules .turbo"
  },
  "dependencies": {
    "@autonomy/agent-manager": "workspace:*",
    "@autonomy/conductor": "workspace:*",
    "@autonomy/cron-manager": "workspace:*",
    "@pyx-memory/client": "workspace:*",
    "@pyx-memory/shared": "workspace:*",
    "@autonomy/plugin-system": "workspace:*",
    "@autonomy/shared": "workspace:*"
  }
}
