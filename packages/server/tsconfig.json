{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@autonomy/shared": ["../shared/src/index.ts"],
      "@autonomy/shared/*": ["../shared/src/*"],
      "@autonomy/conductor": ["../conductor/src/index.ts"],
      "@autonomy/conductor/*": ["../conductor/src/*"],
      "@autonomy/agent-manager": ["../agent-manager/src/index.ts"],
      "@autonomy/agent-manager/*": ["../agent-manager/src/*"],
      "@autonomy/memory": ["../memory/src/index.ts"],
      "@autonomy/memory/*": ["../memory/src/*"],
      "@autonomy/cron-manager": ["../cron-manager/src/index.ts"],
      "@autonomy/cron-manager/*": ["../cron-manager/src/*"],
      "@autonomy/control-plane": ["../control-plane/src/index.ts"],
      "@autonomy/control-plane/*": ["../control-plane/src/*"],
      "@autonomy/plugin-system": ["../plugin-system/src/index.ts"],
      "@autonomy/plugin-system/*": ["../plugin-system/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "__tests__"]
}
